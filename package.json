{
  "name": "qe_sauce.playwright",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:smoke": "npx playwright test --grep @smoke",
    "test:sanity": "npx playwright test --grep \"@smoke|@sanity\"",
    "test:Patching": "npx playwright test --grep @Patching",
    "test:regression:requests": "npx playwright test \"Requests\" --workers=11 --fully-parallel --reporter=blob --blob-report-dir=blob-report/requests",
    "test:regression:account-services-manager": "npx playwright test \"Account Services Manager\" --workers=5 --fully-parallel --reporter=blob --blob-report-dir=blob-report/account-services-manager",
    "test:regression:merge": "npx playwright merge-reports --reporter=html ./blob-report",
    "test:regression": "npm run test:regression:requests && npm run test:regression:account-services-manager && npm run test:regression:merge",
    "test:e2e": "npx playwright test --grep @E2E",
    "report": "npx playwright show-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "playwright-bdd": "^8.5.0"
  }
}